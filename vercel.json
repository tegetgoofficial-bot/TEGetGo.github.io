{
  "installCommand": "npm install --force",
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" },
    { "src": "main.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "main.py" },
    { "source": "/go/(.*)", "destination": "main.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
